{
  "appId":   "com.coilms.app",
  "appName": "CoilMS",
  "webDir":  "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor":   "#0f172a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration":    2000,
      "backgroundColor":       "#0f172a",
      "androidSplashResourceName": "splash",
      "showSpinner":           false
    }
  }
}
